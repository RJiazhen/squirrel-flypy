#!/bin/bash
set -e

# Reads the current GUI login user so postinstall operations target the right account.
login_user=`/usr/bin/stat -f%Su /dev/console`
# Resolves the login user's home directory for user-scoped Rime data path.
login_home=`/usr/bin/dscl . -read "/Users/${login_user}" NFSHomeDirectory | /usr/bin/awk '{print $2}'`
# Defines app bundle and runtime paths inside the installed destination root.
squirrel_install_location="/Library/Input Methods"
squirrel_app_root="${squirrel_install_location}/SquirrelFlypy.app"
squirrel_executable="${squirrel_app_root}/Contents/MacOS/SquirrelFlypy"
rime_package_installer="${squirrel_app_root}/Contents/MacOS/rime-install"
rime_shared_data_path="${squirrel_app_root}/Contents/SharedSupport"
# Bundled flypy reference config is copied from this directory when available.
rime_flypy_config_path="${rime_shared_data_path}/flypy-rime-config"
# User writable Rime config directory for Squirrel Flypy.
rime_user_data_path="${login_home}/Library/Rime Flypy"

# Stops running Squirrel process before replacing files and deploying.
/usr/bin/sudo -u "${login_user}" /usr/bin/killall SquirrelFlypy > /dev/null || true

# Ensures the input source is registered after installation.
"${squirrel_executable}" --register-input-source

# Copies bundled flypy config files into user data directory with overwrite.
/usr/bin/sudo -u "${login_user}" /bin/mkdir -p "${rime_user_data_path}"
if [ -d "${rime_flypy_config_path}" ]; then
    /usr/bin/sudo -u "${login_user}" /bin/cp -Rf "${rime_flypy_config_path}/." "${rime_user_data_path}/"
elif [ -f "${rime_shared_data_path}/flypy.schema.yaml" ]; then
    # Fallback for debug/dev bundles where flypy files are flattened under SharedSupport.
    for config_file in "${rime_shared_data_path}"/*.yaml "${rime_shared_data_path}"/*.txt "${rime_shared_data_path}"/*.lua; do
        [ -e "${config_file}" ] || continue
        /usr/bin/sudo -u "${login_user}" /bin/cp -f "${config_file}" "${rime_user_data_path}/"
    done
    for config_dir in "${rime_shared_data_path}/lua" "${rime_shared_data_path}/opencc"; do
        [ -d "${config_dir}" ] || continue
        /usr/bin/sudo -u "${login_user}" /bin/cp -Rf "${config_dir}" "${rime_user_data_path}/"
    done
else
    echo "postinstall: missing bundled flypy config. expected ${rime_flypy_config_path} or flypy.schema.yaml in ${rime_shared_data_path}" >&2
    exit 1
fi

# Builds schemas from SharedSupport unless explicitly disabled for fast debug install.
if [ -z "${RIME_NO_PREBUILD}" ]; then
    pushd "${rime_shared_data_path}" > /dev/null
    "${squirrel_executable}" --build
    popd > /dev/null
fi && (
    # Enables and switches to the installed input source for immediate availability.
    /usr/bin/sudo -u "${login_user}" "${squirrel_executable}" --enable-input-source
    /usr/bin/sudo -u "${login_user}" "${squirrel_executable}" --select-input-source
)
